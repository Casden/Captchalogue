# Copy this file to .env and fill in values. Never commit .env.

# HTTPS RPC URL for Sepolia (Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Deployer wallet: private key only for a Sepolia test wallet (never mainnet / real funds)
# Omit the "0x" prefix or include it — Hardhat accepts both forms.
SEPOLIA_PRIVATE_KEY=YOUR_64_HEX_CHAR_PRIVATE_KEY

# Optional: for contract verification on Sepolia via Etherscan API
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

